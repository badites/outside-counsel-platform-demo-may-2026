# Database
# Local: file:./prisma/dev.db
# Turso (for Vercel): libsql://your-db-name.turso.io?authToken=your-token
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Email (Mailtrap for dev)
EMAIL_SERVER_HOST="sandbox.smtp.mailtrap.io"
EMAIL_SERVER_PORT=2525
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@counsel-directory.local"

# Anthropic API (for AI features — search assistant, RFP assistant)
# If set, all users share this key. If not set, users must enter their own key.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
